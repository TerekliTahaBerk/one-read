{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "prisma migrate deploy && next build",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/daily",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/one-lingo",
      "schedule": "0 4 * * *"
    },
    {
      "path": "/api/cron/one-film",
      "schedule": "0 4 * * *"
    }
  ]
}
