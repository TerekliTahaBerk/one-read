// OneRead — database schema
// Reference: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("PRISMA_DATABASE_URL")
}

/// A subscriber to the OneRead morning newsletter.
model Subscriber {
  id    String @id @default(cuid())
  email String @unique

  /// Display labels the user picked in the signup form (kept verbatim).
  interests String[]

  /// Canonical topic slug used by the personalization engine.
  primaryInterest String?

  /// Canonical topic slugs of remaining selected interests.
  secondaryInterests String[]

  /// "English" | "Turkish" | "Any"
  sourceLanguage  String?
  /// Summary language name, e.g. "English" | "Turkish" | "Spanish" | "French" | "German"
  summaryLanguage String?

  /// IANA timezone, used to determine local 7 AM.
  timezone     String? @default("Europe/Istanbul")
  /// Local hour-of-day delivery target.
  deliveryHour Int     @default(7)

  /// "beginner" | "intermediate" | "advanced" | "mixed"
  preferredDifficulty String @default("mixed")

  /// Last N topic slugs sent, most recent first. Used for novelty + rotation.
  recentlySentTopics     String[]
  /// Last N article ids sent, most recent first.
  recentlySentArticleIds String[]

  /// Lightweight feedback profile JSON.
  feedbackProfile Json?

  lastSentAt     DateTime?
  unsubscribedAt DateTime?

  /// Set when the user completes (simulated) payment. Non-null + status != UNSUBSCRIBED ⇒ subscribed.
  subscribedAt    DateTime?
  /// "monthly"
  billingInterval String?

  /// "PENDING_PREFERENCES" | "ACTIVE" | "PAUSED" | "UNSUBSCRIBED"
  status    String   @default("PENDING_PREFERENCES")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  feedbacks Feedback[]
  sends     DailySend[]

  @@index([status])
  @@index([summaryLanguage, status])
}

/// Umbrella-level identity: one row per unique email across all OneRead
/// products. A Contact can hold many ProductSubscriptions (one-article today,
/// one-lingo / one-goal later).
model Contact {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions    ProductSubscription[]
  lingoPreferences LingoPreferences[]
  lingoSends       LingoDailySend[]
  filmPreferences  FilmPreferences[]
  filmSends        FilmDailySend[]
}

/// A single product subscription for a Contact. Holds the access lifecycle,
/// trial window, billing/provider state, and (independently) email-delivery
/// status. Access status and email-delivery status are intentionally separate
/// axes — unsubscribing from emails must never cancel billing.
model ProductSubscription {
  id         String  @id @default(cuid())
  contactId  String
  contact    Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  /// Product slug, e.g. "one-article".
  productKey String

  /// Access lifecycle:
  /// "PENDING_PREFERENCES" | "PENDING_CHECKOUT" | "TRIALING"
  /// | "TRIAL_EXPIRED" | "ACTIVE_PAID" | "PAST_DUE" | "CANCELED"
  /// | "EXPIRED" | "ADMIN_OVERRIDE"
  status String @default("PENDING_PREFERENCES")

  // Trial
  trialStartedAt DateTime?
  trialEndsAt    DateTime?
  /// Set once the first trial is consumed; guards against trial resets.
  trialUsedAt    DateTime?

  // Billing
  /// "monthly"
  plan                      String?
  /// "polar" | "stripe" | "lemonsqueezy" | "mock"
  paymentProvider           String?
  providerCustomerId        String?
  providerSubscriptionId    String?
  providerCheckoutSessionId String?
  currentPeriodStart        DateTime?
  currentPeriodEnd          DateTime?
  cancelAtPeriodEnd         Boolean   @default(false)
  canceledAt                DateTime?
  pastDueAt                 DateTime?
  paidAt                    DateTime?

  // Email delivery (independent of access)
  /// "SUBSCRIBED" | "UNSUBSCRIBED" | "SUPPRESSED"
  emailDeliveryStatus String    @default("SUBSCRIBED")
  /// Opaque token for unsubscribe links (in addition to the per-send id).
  unsubscribeToken    String    @unique @default(cuid())
  lastSentAt          DateTime?

  // Admin
  adminOverride Boolean @default(false)
  adminNote     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  preferences      ArticlePreferences?
  lingoPreferences LingoPreferences?
  filmPreferences  FilmPreferences?
  feedbacks        Feedback[]
  sends            DailySend[]
  lingoSends       LingoDailySend[]
  filmSends        FilmDailySend[]

  @@unique([contactId, productKey])
  @@index([productKey, status])
  @@index([trialEndsAt])
  @@index([providerSubscriptionId])
}

/// One-Article-specific personalization preferences for a ProductSubscription.
model ArticlePreferences {
  id                    String              @id @default(cuid())
  productSubscriptionId String              @unique
  subscription          ProductSubscription @relation(fields: [productSubscriptionId], references: [id], onDelete: Cascade)

  /// Display labels the user picked in the signup form (kept verbatim).
  interests          String[]
  /// Canonical topic slug used by the personalization engine.
  primaryInterest    String?
  /// Canonical topic slugs of remaining selected interests.
  secondaryInterests String[]

  /// "English" | "Turkish" | "Any"
  sourceLanguage  String?
  /// Summary language name, e.g. "English" | "Turkish" | "Spanish" | "French" | "German"
  summaryLanguage String?

  /// IANA timezone, used to determine local 7 AM.
  timezone            String? @default("Europe/Istanbul")
  /// Local hour-of-day delivery target.
  deliveryHour        Int     @default(7)
  /// "beginner" | "intermediate" | "advanced" | "mixed"
  preferredDifficulty String  @default("mixed")

  /// Last N topic slugs sent, most recent first. Used for novelty + rotation.
  recentlySentTopics     String[]
  /// Last N article ids sent, most recent first.
  recentlySentArticleIds String[]

  /// Lightweight feedback profile JSON.
  feedbackProfile Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Append-only log of billing-provider webhook events. The unique
/// providerEventId gives us idempotency: a duplicate webhook is a no-op.
model BillingEvent {
  id              String    @id @default(cuid())
  provider        String
  providerEventId String    @unique
  type            String
  payload         Json
  processedAt     DateTime?
  createdAt       DateTime  @default(now())
}

/// A configured RSS / Atom source, persisted from the seed list in
/// lib/sources.ts. Useful for observability and runtime overrides.
model Source {
  id               String    @id @default(cuid())
  /// Stable slug, e.g. "openai-blog".
  slug             String    @unique
  name             String
  feedUrl          String    @unique
  homepage         String?
  /// Default top-level topic slug for items from this source.
  defaultTopic     String
  /// Optional default subtopics.
  defaultSubtopics String[]
  /// "English" | "Turkish" | …
  language         String    @default("English")
  /// True if the feed is enabled in the daily run.
  active           Boolean   @default(true)
  /// Free-form notes (why we chose it, throttling, etc.).
  notes            String?
  lastFetchedAt    DateTime?
  lastError        String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

/// A candidate article ingested from any source.
model Article {
  id                String    @id @default(cuid())
  url               String    @unique
  /// Normalized URL used for stronger dedupe across slightly different
  /// surface forms (utm params stripped, trailing slash removed, etc.).
  canonicalUrl      String?   @unique
  title             String
  sourceName        String
  sourceLanguage    String
  topic             String
  subtopics         String[]
  detectedInterests String[]
  tags              String[]
  publishedAt       DateTime?
  ingestedAt        DateTime  @default(now())

  qualityScore     Float @default(0)
  usefulnessScore  Float @default(0)
  morningReadScore Float @default(0)
  originalityScore Float @default(0)
  readabilityScore Float @default(0)

  difficulty String @default("mixed")

  /// Original RSS excerpt (always kept).
  rawExcerpt           String? @db.Text
  /// Cleaned full text from readability extraction (may be null).
  cleanedText          String? @db.Text
  /// 0..1 — how confident we are in `cleanedText` quality.
  extractionConfidence Float?

  reasonForSelection String? @db.Text
  rejectionReason    String? @db.Text

  /// "PENDING" | "SCORED" | "REJECTED"
  scoringStatus String @default("PENDING")

  picks TopicDailyPick[]

  @@index([topic, sourceLanguage])
  @@index([ingestedAt])
  @@index([scoringStatus])
}

/// One best article per (date, topic, sourceLanguage).
model TopicDailyPick {
  id             String   @id @default(cuid())
  date           DateTime @db.Date
  topic          String
  subtopics      String[]
  sourceLanguage String

  articleId    String?
  article      Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)
  articleTitle String
  sourceName   String

  score              Float
  reasonForSelection String? @db.Text

  /// Editorial readiness — owned by the pipeline. "DRAFT" | "READY" | "REJECTED" | "SENT"
  status String @default("DRAFT")

  /// Admin approval lifecycle — a thin layer over the editorial pipeline,
  /// independent of `status`. When ONE_ARTICLE_REQUIRE_APPROVAL is enabled,
  /// only APPROVED/SCHEDULED picks are sent. Default keeps current behavior.
  /// "PENDING" | "APPROVED" | "SCHEDULED" | "CANCELED"
  approvalStatus String    @default("PENDING")
  /// The 07:00 Europe/Istanbul send instant (stored UTC) chosen by an admin.
  scheduledFor   DateTime?
  approvedAt     DateTime?
  approvedBy     String?
  adminNotes     String?   @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  summaries Summary[]
  sends     DailySend[]

  @@unique([date, topic, sourceLanguage])
  @@index([date, status])
  @@index([approvalStatus])
  @@index([scheduledFor])
}

/// Cached summary for a TopicDailyPick.
model Summary {
  id               String         @id @default(cuid())
  topicDailyPickId String
  pick             TopicDailyPick @relation(fields: [topicDailyPickId], references: [id], onDelete: Cascade)

  summaryLanguage String
  primaryTopic    String
  difficulty      String @default("mixed")

  /// Compact plain text summary used as the email body.
  bodyText String  @db.Text
  bodyHtml String? @db.Text

  /// Full structured LLM output (subject, threeSentenceSummary, etc.).
  /// Null for heuristic summaries.
  structuredJson  Json?
  /// LLM-reported confidence in [0, 100].
  confidence      Float?
  /// "DRAFT" | "READY" | "REJECTED"
  status          String  @default("READY")
  /// Provider id ("openai/gpt-4o-mini") for observability.
  generator       String?
  rejectionReason String? @db.Text

  /// Optional admin overrides for the rendered email. Overrides preserve the
  /// generated fields, and the send path applies them at render time.
  subjectOverride     String?
  previewTextOverride String?
  bodyTextOverride    String? @db.Text
  bodyHtmlOverride    String? @db.Text
  structuredJsonOverride Json?
  adminEditedAt       DateTime?

  createdAt DateTime @default(now())

  @@unique([topicDailyPickId, summaryLanguage, primaryTopic, difficulty])
}

/// Append-only record of every mutating admin action, for operational
/// accountability. Never stores the admin token itself — only a short,
/// non-reversible actor fingerprint (see lib/admin/auth.ts).
model AdminAuditLog {
  id         String   @id @default(cuid())
  actor      String
  action     String
  targetType String
  targetId   String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([targetType, targetId])
  @@index([createdAt])
}

/// Structured operational history for cron/admin pipeline runs. This is
/// intentionally product-scoped so future products can use it without creating
/// another audit system. Secret values must never be stored in metadata.
model OperationalRun {
  id              String    @id @default(cuid())
  productKey      String
  route           String
  startedAt       DateTime  @default(now())
  finishedAt      DateTime?
  status          String    @default("RUNNING")
  dryRun          Boolean   @default(false)
  requireApproval Boolean   @default(true)
  generatedCount  Int       @default(0)
  sentCount       Int       @default(0)
  skippedCount    Int       @default(0)
  failedCount     Int       @default(0)
  error           String?   @db.Text
  metadata        Json?

  @@index([productKey, startedAt])
  @@index([route, startedAt])
  @@index([status])
}

/// The single article a subscriber receives on a given day.
model DailySend {
  id   String   @id @default(cuid())
  date DateTime @db.Date

  subscriberId String
  subscriber   Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  /// New model link (additive during migration; becomes the source of truth
  /// at cutover). Nullable until the backfill has run for every row.
  productSubscriptionId String?
  productSubscription   ProductSubscription? @relation(fields: [productSubscriptionId], references: [id], onDelete: Cascade)

  topicDailyPickId String
  pick             TopicDailyPick @relation(fields: [topicDailyPickId], references: [id], onDelete: Cascade)

  summaryLanguage   String
  matchedTopic      String
  personalizedScore Float

  /// "QUEUED" | "SENT" | "FAILED" | "SKIPPED"
  status         String    @default("QUEUED")
  emailMessageId String?
  error          String?
  sentAt         DateTime?
  createdAt      DateTime  @default(now())

  @@unique([date, subscriberId])
  @@index([date, status])
}

/// User reaction to a delivered article.
model Feedback {
  id           String     @id @default(cuid())
  subscriberId String
  subscriber   Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  /// New model link (additive during migration; becomes the source of truth
  /// at cutover). Nullable until the backfill has run for every row.
  productSubscriptionId String?
  productSubscription   ProductSubscription? @relation(fields: [productSubscriptionId], references: [id], onDelete: Cascade)

  articleId  String?
  topic      String?
  sourceName String?

  /// "loved" | "liked" | "meh" | "disliked"
  reaction  String
  createdAt DateTime @default(now())

  @@index([subscriberId, createdAt])
}

/// One-time email verification codes for the public OneArticle signup /
/// preferences flow. Proves a user controls an email before they can edit
/// preferences. Never stores the raw 6-digit code — only an HMAC hash keyed by
/// EMAIL_VERIFICATION_SECRET. Verification proves email ownership only; it never
/// grants billing access (Polar remains the source of truth).
model EmailVerificationCode {
  id       String @id @default(cuid())
  email    String
  /// HMAC-SHA256 of the 6-digit code (never the plaintext code).
  codeHash String
  /// "one-article-signup" | "one-article-preferences"
  /// | "one-lingo-signup" | "one-lingo-preferences"
  /// | "one-film-signup" | "one-film-preferences"
  purpose  String

  expiresAt   DateTime
  consumedAt  DateTime?
  attempts    Int       @default(0)
  maxAttempts Int       @default(5)
  /// Earliest time a new code may be requested for this email+purpose.
  resendAfter DateTime?

  /// Hashed request metadata for abuse limiting — never raw IP / UA.
  ipHash        String?
  userAgentHash String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email, purpose])
  @@index([expiresAt])
}

// ------------------------------------------------------------------------
// OneLingo — language-learning product
// ------------------------------------------------------------------------

/// OneLingo-specific preferences for a ProductSubscription (productKey =
/// "one-lingo"). Sibling to ArticlePreferences; the two never overlap because a
/// ProductSubscription is scoped to a single product. Completing preferences
/// never grants access — Polar remains the source of truth.
model LingoPreferences {
  id                    String @id @default(cuid())
  contactId             String
  productSubscriptionId String @unique

  /// "English" | "Spanish" | "French" | "German" | "Italian" | "Turkish"
  targetLanguage String
  /// "English" | "Turkish" — the language explanations are written in.
  nativeLanguage String
  /// "Beginner" | "Elementary" | "Intermediate" | "Upper-intermediate" | "Advanced"
  level          String
  /// "Travel" | "Work" | "School" | "Conversation" | "Reading" | "Exam preparation" | "General improvement"
  learningGoal   String
  /// "Vocabulary-first" | "Phrase-first" | "Grammar-light" | "Real-life examples" | "Mixed"
  practiceStyle  String
  /// Display labels the user picked (kept verbatim).
  interests      String[]
  minutesPerDay  Int      @default(5)

  wantsVocabulary  Boolean @default(true)
  wantsPhrases     Boolean @default(true)
  wantsGrammar     Boolean @default(true)
  wantsMiniQuiz    Boolean @default(true)
  wantsCultureNote Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contact             Contact             @relation(fields: [contactId], references: [id], onDelete: Cascade)
  productSubscription ProductSubscription @relation(fields: [productSubscriptionId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([targetLanguage])
  @@index([level])
}

/// A generated daily practice lesson, shared across all users in a segment
/// (targetLanguage + nativeLanguage + level) for a given date. Stored once and
/// reused — never regenerated unless an admin explicitly requests it.
model LingoDailyLesson {
  id             String   @id @default(cuid())
  lessonDate     DateTime @db.Date
  targetLanguage String
  nativeLanguage String
  level          String
  /// e.g. "english__turkish__intermediate".
  segmentKey     String

  title       String
  subject     String
  previewText String?
  /// Full structured lesson (sections, words, phrase, grammar, quiz, answers).
  contentJson Json
  htmlBody    String? @db.Text
  textBody    String? @db.Text

  /// "GENERATED" | "NOT_GENERATED" | "FAILED"
  status         String    @default("GENERATED")
  /// "PENDING" | "APPROVED" | "SCHEDULED" | "CANCELED" | "NEEDS_REVIEW"
  approvalStatus String    @default("PENDING")
  /// The 07:00 Europe/Istanbul send instant (stored UTC) chosen by an admin.
  scheduledFor   DateTime?
  approvedAt     DateTime?
  approvedBy     String?
  adminNotes     String?   @db.Text

  generationProvider String?
  generationModel    String?
  generationMetadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sends LingoDailySend[]

  @@unique([lessonDate, segmentKey])
  @@index([lessonDate])
  @@index([targetLanguage, nativeLanguage, level])
  @@index([approvalStatus])
}

/// One OneLingo email per (date, contact). The unique constraint guarantees
/// idempotent daily sends — the pipeline can safely retry.
model LingoDailySend {
  id                    String   @id @default(cuid())
  lessonDate            DateTime @db.Date
  contactId             String
  productSubscriptionId String
  lingoDailyLessonId    String

  /// "QUEUED" | "SENT" | "FAILED" | "SKIPPED"
  status            String
  sentAt            DateTime?
  skippedReason     String?
  failedReason      String?
  providerMessageId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contact             Contact             @relation(fields: [contactId], references: [id], onDelete: Cascade)
  productSubscription ProductSubscription @relation(fields: [productSubscriptionId], references: [id], onDelete: Cascade)
  lesson              LingoDailyLesson    @relation(fields: [lingoDailyLessonId], references: [id], onDelete: Cascade)

  @@unique([lessonDate, contactId])
  @@index([lingoDailyLessonId])
  @@index([status])
}

// ------------------------------------------------------------------------
// OneFilm — daily film-note product
// ------------------------------------------------------------------------

/// OneFilm-specific preferences for a ProductSubscription (productKey =
/// "one-film"). Completing preferences never grants access — Polar is the
/// source of truth.
model FilmPreferences {
  id                    String @id @default(cuid())
  contactId             String
  productSubscriptionId String @unique

  /// "English" | "Turkish"
  emailLanguage     String
  preferredGenres   String[]
  moods             String[]
  decades           String[]
  languages         String[]
  platforms         String[]
  /// "Spoiler-free" | "Spoiler-light" | "Full analysis allowed"
  spoilerPreference String   @default("spoiler-light")
  /// "Popular films" | "Hidden gems" | "Classics" | "Mixed"
  familiarity       String   @default("mixed")
  /// "Under 90 minutes" | "90–120 minutes" | "Long films are fine" | "Any"
  runtimePreference String   @default("any")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contact             Contact             @relation(fields: [contactId], references: [id], onDelete: Cascade)
  productSubscription ProductSubscription @relation(fields: [productSubscriptionId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([emailLanguage])
}

/// A generated daily OneFilm note, shared across a segment (emailLanguage +
/// genre/mood/spoiler cluster) for a given date. Commentary is original;
/// factual metadata is only present when grounded (admin-provided or verified).
model FilmDailyIssue {
  id         String   @id @default(cuid())
  issueDate  DateTime @db.Date
  segmentKey String

  emailLanguage String
  genres        String[]
  moods         String[]

  filmTitle      String?
  filmYear       Int?
  director       String?
  filmLanguage   String?
  runtimeMinutes Int?
  sourceUrl      String?

  title       String
  subject     String
  previewText String?
  contentJson Json
  htmlBody    String? @db.Text
  textBody    String? @db.Text

  /// "GENERATED" | "NOT_GENERATED" | "NO_FILM" | "FAILED"
  status         String    @default("GENERATED")
  /// "PENDING" | "APPROVED" | "SCHEDULED" | "CANCELED" | "NEEDS_REVIEW"
  approvalStatus String    @default("PENDING")
  scheduledFor   DateTime?
  approvedAt     DateTime?
  approvedBy     String?
  adminNotes     String?   @db.Text

  generationProvider String?
  generationModel    String?
  generationMetadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sends FilmDailySend[]

  @@unique([issueDate, segmentKey])
  @@index([issueDate])
  @@index([emailLanguage])
  @@index([approvalStatus])
}

/// One OneFilm email per (date, contact). Idempotent daily sends.
model FilmDailySend {
  id                    String   @id @default(cuid())
  issueDate             DateTime @db.Date
  contactId             String
  productSubscriptionId String
  filmDailyIssueId      String

  /// "QUEUED" | "SENT" | "FAILED" | "SKIPPED"
  status            String
  sentAt            DateTime?
  skippedReason     String?
  failedReason      String?
  providerMessageId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contact             Contact             @relation(fields: [contactId], references: [id], onDelete: Cascade)
  productSubscription ProductSubscription @relation(fields: [productSubscriptionId], references: [id], onDelete: Cascade)
  issue               FilmDailyIssue      @relation(fields: [filmDailyIssueId], references: [id], onDelete: Cascade)

  @@unique([issueDate, contactId])
  @@index([filmDailyIssueId])
  @@index([status])
}

/// A manually-curated film entry for OneFilm. Factual metadata is admin-entered
/// (or from a verified provider); the generator writes original commentary on
/// top but never invents cast/awards/ratings/availability.
model FilmCatalogEntry {
  id             String    @id @default(cuid())
  title          String
  year           Int?
  director       String?
  /// Original-language name of the film.
  filmLanguage   String?
  runtimeMinutes Int?
  sourceUrl      String?
  /// Admin note / framing seed — original, not a copied review.
  adminNote      String?   @db.Text
  genres         String[]
  moods          String[]
  /// "Spoiler-free" | "Spoiler-light" | "Full analysis allowed"
  spoilerLevel   String    @default("spoiler-light")
  usedAt         DateTime?
  createdBy      String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([usedAt])
}
