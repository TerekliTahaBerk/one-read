# --- Database ---------------------------------------------------------------
# Pooled connection string used by the Prisma client at runtime.
# On Vercel Postgres / Neon this is the URL ending in ?pgbouncer=true&...
PRISMA_DATABASE_URL=

# Direct (non-pooled) connection. Optional locally; Prisma migrate will use
# this if present. Set both DATABASE_URL and POSTGRES_URL on Vercel as needed
# for compatibility with @vercel/postgres / other tooling.
DATABASE_URL=
POSTGRES_URL=

# --- Email (Resend) ---------------------------------------------------------
# Create at https://resend.com/api-keys
RESEND_API_KEY=

# Verified sender, e.g. "OneRead <hello@oneread.email>".
# `FROM_EMAIL` is the canonical name; `RESEND_FROM` is accepted as a legacy
# alias. If neither is set, the daily pipeline logs a clear error in
# production and the dev fallback "One Read <onboarding@resend.dev>" is used
# (which only delivers to the Resend account owner).
FROM_EMAIL="OneRead <hello@oneread.email>"
# RESEND_FROM=  (legacy alias, optional)

# --- OneArticle email verification -----------------------------------------
# Signed-cookie + code HMAC secret. REQUIRED for the verify-before-preferences
# flow. Use a long random string; codes/sessions are invalid without it.
EMAIL_VERIFICATION_SECRET=
# Code lifetime, resend cooldown, and max wrong attempts (defaults shown).
EMAIL_VERIFICATION_CODE_TTL_MINUTES=10
EMAIL_VERIFICATION_RESEND_COOLDOWN_SECONDS=60
EMAIL_VERIFICATION_MAX_ATTEMPTS=5

# --- Editorial pipeline ----------------------------------------------------
# Required for the daily cron handler. Vercel Cron sends this as
# "Authorization: Bearer <CRON_SECRET>" automatically.
CRON_SECRET=

# Admin login. Use a long random ADMIN_SESSION_SECRET and a generated password
# hash; never commit real credentials. ADMIN_PASSWORD is accepted only outside
# production as a local fallback.
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=

# Internal/server admin token fallback for API callers. Pick any opaque random
# string you can keep secret.
ADMIN_TOKEN=

# Admin workflow flags. These default to enabled unless explicitly set false.
ONE_ARTICLE_REQUIRE_APPROVAL=true
ONE_ARTICLE_CRON_ENABLED=true
ONE_ARTICLE_DRY_RUN=false
ADMIN_MUTATIONS_ENABLED=true
ADMIN_SEND_ACTIONS_ENABLED=true

# Public origin used in email links (feedback + unsubscribe).
PUBLIC_BASE_URL=https://oneread.email
NEXT_PUBLIC_BASE_URL=https://oneread.email

# --- LLM provider (production summarization + scoring) ---------------------
# One of: "gemini", "openai", "anthropic", "" (heuristic fallback).
# Gemini is the production brain for all four products. openai/anthropic stay
# supported for OneArticle as additive fallbacks.
AI_PROVIDER=gemini

# Google Gemini — required when AI_PROVIDER=gemini. Powers OneArticle,
# OneLingo, OneNews, OneFilm. Set this as a *Sensitive* env var in your host;
# never commit it. Status surfaces in /admin/settings as configured/missing.
GEMINI_API_KEY=
# Per-task model selection. Safe defaults live in lib/ai/gemini.ts — override
# here without touching code. Fast = cheap classification, Quality = final
# content, Reasoning = harder structured tasks.
# Defaults are gemini-2.5-flash for all tiers (reliable on standard keys;
# gemini-2.5-pro may be rate-limited/unavailable on lower tiers). Switch the
# quality/reasoning tiers to gemini-2.5-pro once a pro-capable key is in place.
GEMINI_MODEL_FAST=gemini-2.5-flash
GEMINI_MODEL_QUALITY=gemini-2.5-flash
GEMINI_MODEL_REASONING=gemini-2.5-flash
# Generation tuning (optional).
GEMINI_TEMPERATURE_DEFAULT=0.4
GEMINI_MAX_OUTPUT_TOKENS=4096
# Per-call timeout (ms) and retry budget (optional).
# GEMINI_TIMEOUT_MS=45000
# GEMINI_MAX_RETRIES=2

# OpenAI — required when AI_PROVIDER=openai (additive OneArticle fallback).
OPENAI_API_KEY=
# Optional override. Defaults to "gpt-4o-mini".
# AI_MODEL=gpt-4o-mini

# Anthropic — required when AI_PROVIDER=anthropic (additive OneArticle fallback).
ANTHROPIC_API_KEY=
# Optional override. Defaults to "claude-3-5-haiku-latest".
# AI_MODEL=claude-3-5-haiku-latest

# --- Editorial thresholds (optional overrides) ------------------------------
# All have safe defaults in lib/thresholds.ts. Tune only if needed.
# MIN_ARTICLE_SCORE=0.7              # quality bar to become a TopicDailyPick
# MIN_DELIVERY_SCORE=0.6             # personalized score required to send
# MIN_SUMMARY_CONFIDENCE=75          # LLM-reported confidence (0..100)
# MIN_EXTRACTION_CONFIDENCE=0.45     # readability extraction quality
# PER_SOURCE_CANDIDATE_LIMIT=6       # max items kept per RSS feed per run

# --- Billing (Polar) --------------------------------------------------------
# Polar is the production billing provider for OneArticle. Use sandbox locally.
BILLING_PROVIDER=polar
POLAR_ACCESS_TOKEN=
POLAR_SUCCESS_URL=https://oneread.email/article/subscribe/success?checkout_id={CHECKOUT_ID}
POLAR_ONE_ARTICLE_SUCCESS_URL=https://oneread.email/article/subscribe/success?checkout_id={CHECKOUT_ID}
POLAR_ONE_ARTICLE_RETURN_URL=https://oneread.email/article/subscribe
POLAR_WEBHOOK_SECRET=
POLAR_ONE_ARTICLE_PRODUCT_ID=44ef8bae-87eb-40eb-9a07-8b4a97e1434e
POLAR_SERVER=sandbox

# --- OneLingo (daily language-practice product) -----------------------------
# Polar product id for OneLingo. NEVER reuse the OneArticle product id. When
# missing, the public OneLingo page still renders but checkout returns a safe
# "billing not configured" message and admin/settings flags it as missing.
POLAR_ONE_LINGO_PRODUCT_ID=
POLAR_ONE_LINGO_CHECKOUT_URL=
POLAR_ONE_LINGO_SUCCESS_URL=https://oneread.email/lingo/subscribe/success?checkout_id={CHECKOUT_ID}
POLAR_ONE_LINGO_RETURN_URL=https://oneread.email/lingo/subscribe
# Local delivery time + timezone (defaults shown).
ONELINGO_SEND_HOUR_LOCAL=7
ONELINGO_TIMEZONE=Europe/Istanbul
# Require admin approval before a generated lesson can be sent (default true).
ONELINGO_REQUIRE_APPROVAL=true
# Extra safety: force the pipeline into dry-run regardless of caller (default false).
ONELINGO_DRY_RUN=false
# Master switch for the OneLingo daily cron. Off unless explicitly "true".
ONELINGO_CRON_ENABLED=true

# --- OneNews (calm morning-briefing product) --------------------------------
# Polar product id for OneNews. NEVER reuse another product's id. When missing,
# the public OneNews page still renders but checkout returns a safe "billing not
# configured" message and admin/settings flags it as missing. Both spellings
# are accepted (POLAR_ONENEWS_PRODUCT_ID and POLAR_ONE_NEWS_PRODUCT_ID).
POLAR_ONENEWS_PRODUCT_ID=
POLAR_ONE_NEWS_PRODUCT_ID=
POLAR_ONENEWS_SUCCESS_URL=https://oneread.email/news/subscribe/success?checkout_id={CHECKOUT_ID}
POLAR_ONENEWS_RETURN_URL=https://oneread.email/news/subscribe
# Local delivery time + timezone (defaults shown). 04:00 UTC = 07:00 Istanbul.
ONENEWS_SEND_HOUR_LOCAL=7
ONENEWS_TIMEZONE=Europe/Istanbul
# Require admin approval before a generated issue can be sent (default true).
ONENEWS_REQUIRE_APPROVAL=true
# Master switch for the OneNews daily cron. Off unless explicitly "true".
ONENEWS_CRON_ENABLED=false
# Extra safety: force the pipeline into dry-run regardless of caller (default false).
ONENEWS_DRY_RUN=false
# Source ingestion mode: "manual" | "rss". Manual is safest for launch.
ONENEWS_SOURCE_MODE=manual
# Comma-separated allowed RSS source URLs (only used when SOURCE_MODE=rss).
ONENEWS_ALLOWED_SOURCES=

# --- OneFilm (daily film-note product) --------------------------------------
# Polar product id for OneFilm. NEVER reuse another product's id. Both spellings
# accepted (POLAR_ONEFILM_PRODUCT_ID and POLAR_ONE_FILM_PRODUCT_ID).
POLAR_ONEFILM_PRODUCT_ID=
POLAR_ONE_FILM_PRODUCT_ID=
POLAR_ONEFILM_SUCCESS_URL=https://oneread.email/film/subscribe/success?checkout_id={CHECKOUT_ID}
POLAR_ONEFILM_RETURN_URL=https://oneread.email/film/subscribe
ONEFILM_SEND_HOUR_LOCAL=7
ONEFILM_TIMEZONE=Europe/Istanbul
ONEFILM_REQUIRE_APPROVAL=true
ONEFILM_CRON_ENABLED=false
ONEFILM_DRY_RUN=false
# Source mode: "manual" | "api". Manual is safest for launch.
ONEFILM_SOURCE_MODE=manual
# Optional film-metadata provider API key (never invents data if missing).
ONEFILM_FILM_SOURCE_API_KEY=
