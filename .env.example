# --- Database ---------------------------------------------------------------
# Pooled connection string used by the Prisma client at runtime.
# On Vercel Postgres / Neon this is the URL ending in ?pgbouncer=true&...
PRISMA_DATABASE_URL=

# Direct (non-pooled) connection. Optional locally; Prisma migrate will use
# this if present. Set both DATABASE_URL and POSTGRES_URL on Vercel as needed
# for compatibility with @vercel/postgres / other tooling.
DATABASE_URL=
POSTGRES_URL=

# --- Email (Resend) ---------------------------------------------------------
# Create at https://resend.com/api-keys
RESEND_API_KEY=

# Verified sender, e.g. "One Read <hello@oneread.app>".
# `FROM_EMAIL` is the canonical name; `RESEND_FROM` is accepted as a legacy
# alias. If neither is set, the daily pipeline logs a clear error in
# production and the dev fallback "One Read <onboarding@resend.dev>" is used
# (which only delivers to the Resend account owner).
FROM_EMAIL=
# RESEND_FROM=  (legacy alias, optional)

# --- Editorial pipeline ----------------------------------------------------
# Required for the daily cron handler. Vercel Cron sends this as
# "Authorization: Bearer <CRON_SECRET>" automatically.
CRON_SECRET=

# Admin login. Use a long random ADMIN_SESSION_SECRET and a generated password
# hash; never commit real credentials. ADMIN_PASSWORD is accepted only outside
# production as a local fallback.
ADMIN_EMAIL=
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=

# Internal/server admin token fallback for API callers. Pick any opaque random
# string you can keep secret.
ADMIN_TOKEN=

# Admin workflow flags. These default to enabled unless explicitly set false.
ONE_ARTICLE_REQUIRE_APPROVAL=true
ADMIN_MUTATIONS_ENABLED=true
ADMIN_SEND_ACTIONS_ENABLED=true

# Public origin used in email links (feedback + unsubscribe).
PUBLIC_BASE_URL=https://oneread.app

# --- LLM provider (production summarization + scoring) ---------------------
# One of: "openai", "anthropic", "" (heuristic fallback).
AI_PROVIDER=openai

# OpenAI — required when AI_PROVIDER=openai.
OPENAI_API_KEY=
# Optional override. Defaults to "gpt-4o-mini".
# AI_MODEL=gpt-4o-mini

# Anthropic — required when AI_PROVIDER=anthropic.
ANTHROPIC_API_KEY=
# Optional override. Defaults to "claude-3-5-haiku-latest".
# AI_MODEL=claude-3-5-haiku-latest

# --- Editorial thresholds (optional overrides) ------------------------------
# All have safe defaults in lib/thresholds.ts. Tune only if needed.
# MIN_ARTICLE_SCORE=0.7              # quality bar to become a TopicDailyPick
# MIN_DELIVERY_SCORE=0.6             # personalized score required to send
# MIN_SUMMARY_CONFIDENCE=75          # LLM-reported confidence (0..100)
# MIN_EXTRACTION_CONFIDENCE=0.45     # readability extraction quality
# PER_SOURCE_CANDIDATE_LIMIT=6       # max items kept per RSS feed per run

# --- Billing (Polar) --------------------------------------------------------
# Polar is the production billing provider for OneArticle. Use sandbox locally.
BILLING_PROVIDER=polar
POLAR_ACCESS_TOKEN=
POLAR_SUCCESS_URL=https://oneread.app/article/subscribe/success?checkout_id={CHECKOUT_ID}
POLAR_WEBHOOK_SECRET=
POLAR_ONE_ARTICLE_PRODUCT_ID=44ef8bae-87eb-40eb-9a07-8b4a97e1434e
POLAR_SERVER=sandbox
