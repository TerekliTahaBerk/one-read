{
  "name": "one-read",
  "version": "0.1.0",
  "private": true,
  "description": "One article. Every morning. Curated for you.",
  "scripts": {
    "dev": "NODE_OPTIONS=--disable-warning=DEP0169 next dev",
    "build": "prisma generate && next build",
    "start": "NODE_OPTIONS=--disable-warning=DEP0169 next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed-sources": "node --env-file=.env scripts/seed-sources.mjs",
    "seed:demo-articles": "node --import tsx --env-file=.env scripts/seed-demo-articles.ts",
    "demo:preview": "node --import tsx --env-file=.env scripts/demo-preview.ts",
    "ingest": "node --import tsx --env-file=.env scripts/ingest.ts",
    "ingest:only": "node --import tsx --env-file=.env scripts/ingest.ts --no-score",
    "score": "node --import tsx --env-file=.env scripts/score.ts",
    "dry-run": "node --import tsx --env-file=.env scripts/dry-run.ts",
    "lingo:generate": "node --import tsx --env-file=.env scripts/lingo-generate.ts",
    "lingo:dry-run": "node --import tsx --env-file=.env scripts/lingo-dry-run.ts",
    "lingo:send-test": "node --import tsx --env-file=.env scripts/lingo-send-test.ts",
    "inspect:film": "node --import tsx --env-file=.env scripts/inspect-film.ts",
    "film:generate": "node --import tsx --env-file=.env scripts/film-generate.ts",
    "film:dry-run": "node --import tsx --env-file=.env scripts/film-dry-run.ts",
    "film:send-test": "node --import tsx --env-file=.env scripts/film-send-test.ts",
    "film:test-email": "node --import tsx --env-file=.env scripts/film-test-email.ts",
    "inspect:eligibility": "node --import tsx --env-file=.env scripts/inspect-eligibility.ts",
    "inspect:billing": "node --import tsx --env-file=.env scripts/inspect-billing.ts",
    "inspect:lingo": "node --import tsx --env-file=.env scripts/inspect-lingo.ts",
    "fix:local-trials": "node --import tsx --env-file=.env scripts/fix-local-trials-to-pending-checkout.ts",
    "sync:legacy-subscribers": "node --import tsx --env-file=.env scripts/sync-legacy-subscriber-status.ts",
    "mock:billing-fixtures": "node --import tsx --env-file=.env scripts/mock-billing-fixtures.ts",
    "summarize": "node --import tsx --env-file=.env scripts/summarize.ts",
    "ai:status": "node --import tsx --env-file=.env scripts/ai-status.ts",
    "ai:test:article": "node --import tsx --env-file=.env scripts/ai-test-article.ts",
    "ai:test:lingo": "node --import tsx --env-file=.env scripts/ai-test-lingo.ts",
    "ai:test:film": "node --import tsx --env-file=.env scripts/ai-test-film.ts",
    "ai:test:all": "node --import tsx --env-file=.env scripts/ai-test-all.ts",
    "inspect:articles": "node --env-file=.env scripts/inspect-articles.mjs",
    "inspect:rejected": "node --env-file=.env scripts/inspect-rejected.mjs",
    "pipeline:dry": "node --env-file=.env scripts/pipeline-cli.mjs --dry-run",
    "pipeline:run": "node --env-file=.env scripts/pipeline-cli.mjs",
    "pipeline:smoke": "node --env-file=.env scripts/pipeline-smoke.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.27.3",
    "@google/genai": "^2.9.0",
    "@mozilla/readability": "^0.5.0",
    "@polar-sh/sdk": "^0.48.1",
    "@prisma/client": "^5.18.0",
    "@sentry/nextjs": "^9.47.1",
    "jsdom": "^24.1.0",
    "next": "14.2.5",
    "openai": "^4.55.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "resend": "^4.0.1",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.5",
    "postcss": "^8.4.39",
    "prisma": "^5.18.0",
    "tailwindcss": "^3.4.6",
    "tsx": "^4.22.4",
    "typescript": "^5.5.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9",
    "vitest-mock-extended": "^4.0.0"
  }
}
